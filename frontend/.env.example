# Local dev: omit these — Vite proxies /api to localhost:8000
# VITE_API_URL=/api

# Production (Vercel): set in Vercel dashboard → Environment Variables
# RAILWAY_API_URL=https://your-api.up.railway.app
#
# Optional: call Railway directly from the browser (requires CORS_ORIGINS on Railway)
# VITE_API_URL=https://your-api.up.railway.app
