# Groq LLM (required for AI recommendations)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=30
GROQ_MAX_TOKENS=2048

# Application
APP_NAME=Zomato Recommendation API
DEBUG=false

# CORS — JSON array or comma-separated origins
# Local dev (default):
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
# Production (Railway) — add your Vercel URL:
# CORS_ORIGINS=["https://your-app.vercel.app","https://your-app-git-main.vercel.app"]

# Recommendation tuning
MAX_CANDIDATES=30
ADDITIONAL_PREFERENCES_MAX_LENGTH=500

# Frontend (Vercel only — set in Vercel dashboard, not here)
# VITE_API_URL=https://your-api.up.railway.app
