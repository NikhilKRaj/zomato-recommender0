# Groq LLM (required from Phase 3 onward)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=30
GROQ_MAX_TOKENS=2048

# Application
APP_NAME=Zomato Recommendation API
DEBUG=false

# CORS (comma-separated origins for frontend dev server)
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Recommendation tuning
MAX_CANDIDATES=30
ADDITIONAL_PREFERENCES_MAX_LENGTH=500
